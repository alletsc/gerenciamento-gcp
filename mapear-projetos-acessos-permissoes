--2. Projetos na dimensão que NÃO estão nos jobs v2
SELECT
    dim.project_id,
    dim.orgao,
    dim.ambiente
  FROM `rj-iplanrio.brutos_gcp.dim_gcp_project` dim
  LEFT JOIN (
    SELECT DISTINCT project_id
    FROM `rj-iplanrio.brutos_gcp.gcp_bigquery_jobs_v2`
  ) jobs
  ON dim.project_id = jobs.project_id
  WHERE jobs.project_id IS NULL
  ORDER BY dim.project_id;


  -- Nota: Projetos removidos por falta de permissão de acesso:
  -- dados-rio-billing, datario, datario-dev, hackathon-fgv-03-2024,
  -- rj-caio, rj-superapp, rj-superapp-staging, rj-vision-ai


-- Checagem 
WITH all_dim_projects AS (
    SELECT DISTINCT project_id, orgao, ambiente
    FROM `rj-iplanrio.brutos_gcp.dim_gcp_project`
  ),
  jobs_activity AS (
    SELECT
      project_id,
      MAX(creation_time) AS ultimo_job,
      DATE_DIFF(CURRENT_DATE(), DATE(MAX(creation_time)), DAY) AS dias_sem_atividade,
      COUNT(*) AS total_jobs
    FROM `rj-iplanrio.brutos_gcp.gcp_bigquery_jobs_v2`
    GROUP BY project_id
  )

  SELECT
    dim.project_id,
    dim.orgao,
    dim.ambiente,
    COALESCE(jobs.ultimo_job, TIMESTAMP('1970-01-01')) AS ultimo_job,
    COALESCE(jobs.dias_sem_atividade, 999999) AS dias_sem_atividade,
    COALESCE(jobs.total_jobs, 0) AS total_jobs,
    CASE
      WHEN jobs.project_id IS NULL AND dim.project_id IN (
        'dados-rio-billing', 'datario', 'datario-dev', 'hackathon-fgv-03-2024',
        'rj-caio', 'rj-superapp', 'rj-superapp-staging', 'rj-vision-ai'
      ) THEN 'Sem permissão de acesso'
      WHEN jobs.project_id IS NULL THEN 'Inativo (>180 dias sem jobs)'
      WHEN jobs.dias_sem_atividade > 30 THEN 'Baixa atividade'
      ELSE 'Ativo'
    END AS status
  FROM all_dim_projects dim
  LEFT JOIN jobs_activity jobs ON dim.project_id = jobs.project_id
  ORDER BY
    CASE
      WHEN jobs.project_id IS NULL THEN 1
      ELSE 0
    END DESC,
    dias_sem_atividade DESC,
    dim.project_id;

