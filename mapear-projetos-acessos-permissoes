  -- 4. Comparar projetos IPLANRIO na dimensão vs jobs

  -- Projetos IPLANRIO na dimensão

  WITH dim_iplanrio AS (
    SELECT project_id
    FROM `rj-iplanrio.brutos_gcp.dim_gcp_project`
    WHERE orgao = 'IPLANRIO'
  ),
  jobs_projects AS (
    SELECT DISTINCT project_id
    FROM `rj-iplanrio.brutos_gcp.gcp_bigquery_jobs_v2`
  )

  SELECT
    'Apenas na dimensão' AS status,
    d.project_id
  FROM dim_iplanrio d
  LEFT JOIN jobs_projects j ON d.project_id = j.project_id
  WHERE j.project_id IS NULL

  UNION ALL

  SELECT
    'Em ambos' AS status,
    d.project_id
  FROM dim_iplanrio d
  INNER JOIN jobs_projects j ON d.project_id = j.project_id

  ORDER BY status, project_id;
-- ok


-- ----------------------------------------------------

  -- Verificar se projeto tem CUSTO no billing mas SEM jobs registrados
  -- Isso indica problema de permissão ou coleta incompleta

  WITH dim_only AS (
    SELECT project_id FROM `rj-iplanrio.brutos_gcp.dim_gcp_project`
    EXCEPT DISTINCT
    SELECT project_id FROM `rj-iplanrio.brutos_gcp.gcp_bigquery_jobs_v2`
  )

  SELECT
    dim.project_id,
    SUM(b.cost) AS custo_total_6_meses,
    COUNT(DISTINCT b.invoice_competencia_particao) AS meses_com_custo
  FROM dim_only dim
  LEFT JOIN `rj-iplanrio.brutos_gcp.gcp_billing` b
    ON dim.project_id = b.project.id
    AND b.invoice_competencia_particao >= DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH)
    AND b.service.description = 'BigQuery'
  GROUP BY dim.project_id
  HAVING custo_total_6_meses > 0
  ORDER BY custo_total_6_meses DESC;



-- Resolver problema de acesso


  -- Ver qual service account está rodando as queries: dbt-ci-github-rj-iplanrio@rj-iplanrio.iam.gserviceaccount.com e dbt-stella-costa@rj-iplanrio.iam.gserviceaccount.com
  SELECT
    user_email,
    COUNT(*) AS total_execucoes
  FROM `rj-iplanrio.brutos_gcp.gcp_bigquery_jobs_v2`
  WHERE job_type = 'QUERY'
    AND query LIKE '%raw_gcp_bigquery_jobs_v2%'
    AND creation_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 7 DAY)
  GROUP BY user_email
  ORDER BY total_execucoes DESC
  LIMIT 5;


