  --3. Verificar distribuição de projetos por órgão

  SELECT
    orgao,
    COUNT(DISTINCT project_id) AS total_projetos,
    STRING_AGG(DISTINCT project_id ORDER BY project_id) AS projetos
  FROM `rj-iplanrio.brutos_gcp.dim_gcp_project`
  GROUP BY orgao
  ORDER BY total_projetos DESC;

